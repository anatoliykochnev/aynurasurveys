<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/aynurasurveys/db" VERSION="2026042421" COMMENT="XMLDB file for local_aynurasurveys"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">
  <TABLES>

    <TABLE NAME="local_aynurasurveys_rules" COMMENT="Trigger rules mapping events to surveys">
      <FIELDS>
        <FIELD NAME="id"              TYPE="int"  LENGTH="10"  NOTNULL="true"  SEQUENCE="true"/>
        <FIELD NAME="trigger"         TYPE="char" LENGTH="64"  NOTNULL="true"/>
        <FIELD NAME="rulename"        TYPE="char" LENGTH="255" NOTNULL="false" COMMENT="Admin-defined human readable name for this rule"/>
        <FIELD NAME="surveyid"        TYPE="char" LENGTH="128" NOTNULL="true"/>
        <FIELD NAME="surveyname"      TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="scope"           TYPE="char" LENGTH="16"  NOTNULL="true"  DEFAULT="global"/>
        <FIELD NAME="display_context" TYPE="char" LENGTH="16"  NOTNULL="true"  DEFAULT="site"/>
        <FIELD NAME="conditions"      TYPE="text" NOTNULL="false"/>
        <FIELD NAME="valid_from"      TYPE="int"  LENGTH="10"  NOTNULL="false"/>
        <FIELD NAME="valid_until"     TYPE="int"  LENGTH="10"  NOTNULL="false"/>
        <FIELD NAME="delay_minutes"   TYPE="int"  LENGTH="10"  NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="enabled"         TYPE="int"  LENGTH="1"   NOTNULL="true"  DEFAULT="1"/>
        <FIELD NAME="timecreated"     TYPE="int"  LENGTH="10"  NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="timemodified"    TYPE="int"  LENGTH="10"  NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="createdby"       TYPE="int"  LENGTH="10"  NOTNULL="true"  DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="idx_trigger" UNIQUE="false" FIELDS="trigger"/>
        <INDEX NAME="idx_enabled" UNIQUE="false" FIELDS="enabled"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_aynurasurveys_rule_courses" COMMENT="Courses linked to scoped trigger rules">
      <FIELDS>
        <FIELD NAME="id"       TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="ruleid"   TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary"   TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_rule"   TYPE="foreign" FIELDS="ruleid"   REFTABLE="local_aynurasurveys_rules" REFFIELDS="id"/>
        <KEY NAME="fk_course" TYPE="foreign" FIELDS="courseid" REFTABLE="course"                 REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="idx_ruleid"   UNIQUE="false" FIELDS="ruleid"/>
        <INDEX NAME="idx_courseid" UNIQUE="false" FIELDS="courseid"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_aynurasurveys_log" COMMENT="Survey dispatch delivery log">
      <FIELDS>
        <FIELD NAME="id"          TYPE="int"  LENGTH="10"  NOTNULL="true"  SEQUENCE="true"/>
        <FIELD NAME="ruleid"      TYPE="int"  LENGTH="10"  NOTNULL="true"/>
        <FIELD NAME="userid"      TYPE="int"  LENGTH="10"  NOTNULL="true"/>
        <FIELD NAME="surveyid"    TYPE="char" LENGTH="128" NOTNULL="true"/>
        <FIELD NAME="trigger"     TYPE="char" LENGTH="64"  NOTNULL="true"/>
        <FIELD NAME="courseid"    TYPE="int"  LENGTH="10"  NOTNULL="false"/>
        <FIELD NAME="status"      TYPE="char" LENGTH="16"  NOTNULL="true"/>
        <FIELD NAME="statuscode"  TYPE="int"  LENGTH="4"   NOTNULL="false"/>
        <FIELD NAME="response"    TYPE="text" NOTNULL="false"/>
        <FIELD NAME="timecreated" TYPE="int"  LENGTH="10"  NOTNULL="true"  DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_rule" TYPE="foreign" FIELDS="ruleid" REFTABLE="local_aynurasurveys_rules" REFFIELDS="id"/>
        <KEY NAME="fk_user" TYPE="foreign" FIELDS="userid" REFTABLE="user"                   REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="idx_surveyid"          UNIQUE="false" FIELDS="surveyid"/>
        <INDEX NAME="idx_trigger"           UNIQUE="false" FIELDS="trigger"/>
        <INDEX NAME="idx_status"            UNIQUE="false" FIELDS="status"/>
        <INDEX NAME="idx_user_survey_course" UNIQUE="false" FIELDS="userid, surveyid, courseid"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_aynurasurveys_pending" COMMENT="Pending surveys queued to show as modal to users">
      <FIELDS>
        <FIELD NAME="id"              TYPE="int"  LENGTH="10"  NOTNULL="true"  SEQUENCE="true"/>
        <FIELD NAME="userid"          TYPE="int"  LENGTH="10"  NOTNULL="true"/>
        <FIELD NAME="ruleid"          TYPE="int"  LENGTH="10"  NOTNULL="true"/>
        <FIELD NAME="surveyid"        TYPE="char" LENGTH="128" NOTNULL="true"/>
        <FIELD NAME="surveyname"      TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="trigger"         TYPE="char" LENGTH="64"  NOTNULL="true"/>
        <FIELD NAME="rulename"        TYPE="char" LENGTH="255" NOTNULL="false" COMMENT="Admin-defined human readable name for this rule"/>
        <FIELD NAME="courseid"        TYPE="int"  LENGTH="10"  NOTNULL="false"/>
        <FIELD NAME="display_context" TYPE="char" LENGTH="16"  NOTNULL="true"  DEFAULT="site"/>
        <FIELD NAME="questions"       TYPE="text" NOTNULL="false"/>
        <FIELD NAME="language"        TYPE="char" LENGTH="10"  NOTNULL="true"  DEFAULT="en"/>
        <FIELD NAME="show_after"       TYPE="int"  LENGTH="10"  NOTNULL="false"/>
        <FIELD NAME="status"          TYPE="char" LENGTH="16"  NOTNULL="true"  DEFAULT="pending"/>
        <FIELD NAME="timecreated"     TYPE="int"  LENGTH="10"  NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="timeresolved"    TYPE="int"  LENGTH="10"  NOTNULL="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_user" TYPE="foreign" FIELDS="userid" REFTABLE="user"                   REFFIELDS="id"/>
        <KEY NAME="fk_rule" TYPE="foreign" FIELDS="ruleid" REFTABLE="local_aynurasurveys_rules" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="idx_status"       UNIQUE="false" FIELDS="status"/>
        <INDEX NAME="idx_user_pending" UNIQUE="false" FIELDS="userid, status"/>
      </INDEXES>
    </TABLE>

  </TABLES>
</XMLDB>
